{
  "workflow_id": "sdd-assisted-generation-loop",
  "version": "2.0.0",
  "description": "Ciclo de generación asistida y autogeneración SDD Hardened. Orquesta la creación, validación, empaquetado y entrega de artefactos bajo reglas C1-C8.",
  "constraints_applied": ["C1", "C2", "C3", "C4", "C5", "C6", "C7", "C8"],
  "inference_providers": ["OpenRouter", "DashScope", "DeepSeek", "MiniMax"],
  "nodes": [
    {
      "id": "node_01_init_context",
      "type": "validator",
      "title": "Validación de Contexto Inicial (C4)",
      "level": "Junior",
      "action": "validate_bootstrap",
      "script": "scripts/init-agent-context.sh",
      "inputs": {
        "tenant_id": "${env.TENANT_ID}",
        "bootstrap_path": "config/bootstrap-company.json"
      },
      "validation_logic": "Verificar existencia de archivo y coincidencia de tenant_id.",
      "success_output": "Contexto cargado. Variables MAX_RESULTS, TIMEOUT_MS, CONNECTION_LIMIT exportadas.",
      "failure_output": "C4 VIOLATION: tenant_id missing or mismatch.",
      "troubleshooting": {
        "error": "C4 VIOLATION",
        "cause": "Variable de entorno no definida o archivo bootstrap ausente.",
        "fix": "Ejecutar 'export TENANT_ID=x' y verificar ruta del JSON."
      }
    },
    {
      "id": "node_02_load_skills_map",
      "type": "loader",
      "title": "Carga de Mapa de Skills Disponibles",
      "level": "Junior",
      "action": "read_json",
      "source": "02-SKILLS/skill-domains-mapping.md",
      "outputs": ["infra", "db-rag", "comms", "ai", "security"],
      "constraint_check": "C5: Validar que el mapa tenga estructura legible."
    },
    {
      "id": "node_03_select_generation_mode",
      "type": "router",
      "title": "Selección de Modo: Asistido vs Auto",
      "level": "Intermediate",
      "condition": "${env.GENERATION_MODE} == 'AUTO' ? 'auto_pipeline' : 'interactive_assist'",
      "branches": {
        "auto_pipeline": "node_04_auto_gen",
        "interactive_assist": "node_05_interactive_prompt"
      }
    },
    {
      "id": "node_04_auto_gen",
      "type": "generator",
      "title": "Autogeneración Masiva de Skills (C6)",
      "level": "Expert",
      "action": "batch_generate",
      "model": "${env.MODEL_PREFERENCE}",
      "provider": "openrouter_proxy",
      "inputs": {
        "skills_list": "${node_02.outputs}",
        "tenant_id": "${env.TENANT_ID}"
      },
      "constraints": {
        "C1_C2": "Inyectar límites explícitos en prompts.",
        "C3": "Forzar uso de process.env en código generado.",
        "C6": "Usar solo proxy cloud para inferencia."
      },
      "output_dir": ".temp_generated_skills/"
    },
    {
      "id": "node_05_interactive_prompt",
      "type": "input_handler",
      "title": "Captura de Prompt Contextual (Asistido)",
      "level": "Junior",
      "action": "cli_input",
      "prompt_text": "Describe el módulo a generar (ej: 'Conexión Qdrant con tenant_id'):",
      "validation": "No vacío, > 10 caracteres."
    },
    {
      "id": "node_06_single_skill_gen",
      "type": "generator",
      "title": "Generación de Skill Única con Qwen/DeepSeek",
      "level": "Intermediate",
      "action": "single_generate",
      "model": "${env.MODEL_PREFERENCE}",
      "system_prompt": "Eres un ingeniero senior SDD Hardened. Genera código TS/Python cumpliendo C1-C8. Incluye troubleshooting.",
      "user_prompt": "${node_05.input}",
      "output_file": ".temp_generated_skills/single_skill.ts"
    },
    {
      "id": "node_07_validate_c3_secrets",
      "type": "security_scanner",
      "title": "Escaneo de Credenciales Hardcodeadas (C3)",
      "level": "Intermediate",
      "action": "grep_scan",
      "target_dir": ".temp_generated_skills/",
      "patterns": ["api_key\\s*=\\s*['\"]", "password\\s*=\\s*['\"]", "secret\\s*=\\s*['\"]"],
      "fail_on_match": true,
      "error_message": "C3 VIOLATION: Hardcoded secrets detected.",
      "fix_instruction": "Reemplazar literals por process.env.VAR_NAME."
    },
    {
      "id": "node_08_validate_c4_tenant",
      "type": "logic_scanner",
      "title": "Validación de Aislamiento Multi-Tenant (C4)",
      "level": "Intermediate",
      "action": "ast_parse_check",
      "target_dir": ".temp_generated_skills/",
      "check_logic": "Cada función DB/API debe recibir 'tenant_id' como argumento y usarlo en queries/logs.",
      "fail_if_missing": true,
      "error_message": "C4 VIOLATION: tenant_id not enforced in logic."
    },
    {
      "id": "node_09_validate_c1_c2_limits",
      "type": "code_quality_check",
      "title": "Verificación de Límites Explícitos (C1/C2)",
      "level": "Intermediate",
      "action": "regex_check",
      "patterns": ["timeout", "maxResults", "connectionLimit", "LIMIT"],
      "min_occurrences": 1,
      "scope": "database_calls, http_fetches",
      "error_message": "C1/C2 WARNING: Missing explicit limits."
    },
    {
      "id": "node_10_lint_and_format",
      "type": "formatter",
      "title": "Linting y Formateo Automático",
      "level": "Junior",
      "action": "exec_command",
      "command": "npx eslint .temp_generated_skills/ --fix && npx prettier .temp_generated_skills/ --write",
      "ignore_errors": false
    },
    {
      "id": "node_11_unit_test_gen",
      "type": "generator",
      "title": "Generación de Tests Unitarios (C5)",
      "level": "Expert",
      "action": "generate_tests",
      "source_code": ".temp_generated_skills/*.ts",
      "framework": "jest",
      "mock_strategy": "Mockear DB y API calls. Inyectar tenant_id de prueba.",
      "output_dir": ".temp_generated_skills/__tests__/"
    },
    {
      "id": "node_12_run_unit_tests",
      "type": "tester",
      "title": "Ejecución de Tests Unitarios",
      "level": "Intermediate",
      "action": "exec_command",
      "command": "npm test -- .temp_generated_skills/__tests__/",
      "timeout_ms": "${env.TIMEOUT_MS}",
      "fail_on_error": true
    },
    {
      "id": "node_13_integration_smoke_test",
      "type": "integration_tester",
      "title": "Smoke Test de Integración Local",
      "level": "Expert",
      "action": "spin_up_docker_compose",
      "services": ["postgres_test", "qdrant_test"],
      "run_script": "scripts/smoke_test_deploy.ts",
      "cleanup": true,
      "validation": "Verificar conexión DB y respuesta API básica."
    },
    {
      "id": "node_14_generate_docs",
      "type": "documenter",
      "title": "Generación de Documentación Markdown",
      "level": "Junior",
      "action": "parse_comments_to_md",
      "source": ".temp_generated_skills/",
      "template": "05-CONFIGURATIONS/templates/skill-template.md",
      "output": "docs/generated_skills/",
      "include_sections": ["Objetivo", "Código", "Troubleshooting", "Constraints"]
    },
    {
      "id": "node_15_security_audit_deps",
      "type": "security_scanner",
      "title": "Auditoría de Dependencias (C7)",
      "level": "Intermediate",
      "action": "npm_audit",
      "severity_threshold": "high",
      "fail_if_vulns_found": true,
      "output_report": "reports/dependency-audit.json"
    },
    {
      "id": "node_16_prepare_artifact_structure",
      "type": "packager",
      "title": "Preparación de Estructura de Artefacto",
      "level": "Intermediate",
      "action": "copy_files",
      "structure": {
        "src/": ".temp_generated_skills/",
        "config/": "config/bootstrap-company.json, config/.env.example",
        "infra/": "05-CONFIGURATIONS/terraform/modules/",
        "docs/": "docs/generated_skills/",
        "scripts/": "scripts/packager-agentic.sh, scripts/validate-constraints-cli.sh"
      },
      "exclude": ["node_modules", ".git", "*.log"]
    },
    {
      "id": "node_17_inject_env_template",
      "type": "configurator",
      "title": "Inyección de Plantilla .env Segura (C3)",
      "level": "Junior",
      "action": "create_env_example",
      "variables": [
        "TENANT_ID",
        "DB_PRIMARY_DSN",
        "OPENROUTER_API_KEY",
        "QDRANT_URL",
        "MAX_RESULTS",
        "TIMEOUT_MS",
        "CONNECTION_LIMIT"
      ],
      "warning_comment": "# NEVER commit this file with real values. Use vault/secrets manager."
    },
    {
      "id": "node_18_create_zip_archive",
      "type": "packager",
      "title": "Compresión ZIP Final",
      "level": "Intermediate",
      "action": "zip_directory",
      "source_dir": ".temp_artifact_staging/",
      "output_file": "releases/release-${env.TENANT_ID}-${timestamp}.zip",
      "compression_level": 9
    },
    {
      "id": "node_19_sign_and_checksum",
      "type": "security_signer",
      "title": "Firma Digital y Checksum (C8)",
      "level": "Expert",
      "action": "gpg_sign_and_sha256",
      "input_file": "${node_18.output_file}",
      "outputs": [
        "${node_18.output_file}.asc",
        "${node_18.output_file}.sha256"
      ],
      "log_event": "artifact_signed"
    },
    {
      "id": "node_20_notify_and_cleanup",
      "type": "notifier",
      "title": "Notificación de Entrega y Limpieza",
      "level": "Junior",
      "action": "send_slack_webhook",
      "payload": {
        "text": "✅ Deploy Package Ready for Tenant: ${env.TENANT_ID}",
        "attachment": "Artifact: ${node_18.output_file}"
      },
      "cleanup_action": "rm -rf .temp_generated_skills/ .temp_artifact_staging/",
      "final_status": "SUCCESS"
    }
  ],
  "global_error_handling": {
    "retry_policy": {
      "max_retries": 3,
      "backoff_multiplier": 2,
      "initial_delay_ms": 1000
    },
    "notification_channel": "slack_errors",
    "rollback_trigger": "Si node_12 o node_13 fallan, abortar pipeline y limpiar temp dirs."
  },
  "environment_requirements": {
    "node_version": ">=18",
    "python_version": ">=3.9",
    "required_tools": ["zip", "gpg", "docker", "kubectl"],
    "env_vars_mandatory": ["TENANT_ID", "OPENROUTER_API_KEY", "MODEL_PREFERENCE"]
  }
}

