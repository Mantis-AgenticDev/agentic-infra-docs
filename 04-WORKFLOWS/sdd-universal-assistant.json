jq -e '.orchestration_core.validation_profiles | has("tier1-doc") and has("tier2-code") and has("tier3-deploy") and has("tier2-pgvector")' 04-WORKFLOWS/sdd-universal-assistant.json && echo "✅ Validation profiles completos"

# 6. Gates de validación definidos (G-001 a G-007)
