{
  "name": "SDD-Universal-Business-Assistant-v1",
  "meta": { "templateCredsSetupCompleted": false, "sdd_version": "1.0" },
  "active": false,
  "settings": { "executionOrder": "v1", "timezone": "America/Sao_Paulo" },
  "nodes": [
    {
      "type": "n8n-nodes-base.stickyNote",
      "name": "SDD-001: Documentación de Spec",
      "position": [-1200, -800],
      "parameters": { "content": "# 📋 SDD INTEGRATION MAP\n- Trigger: WhatsApp/Telegram/Webhook (mappado a SDR.txt, Hotel Receptionist)\n- Routing: Switch/If/Filter (mappado a Dental Clinic, Restaurant Order)\n- AI Core: Agent + Tools (mappado a RAG Chatbot, VPS Monitor, Video Creation)\n- Memory: Postgres/Redis (mappado a Hotel Guest Journey, SDR Buffer)\n- Storage: Qdrant + MySQL + Sheets (mappado a Lead Router, Dental, Hotel)\n- Constraints: C1-C6 aplicados en cada nodo. tenant_id obligatorio." },
      "typeVersion": 1
    },
    {
      "type": "n8n-nodes-base.webhook",
      "name": "Trigger: Multi-Channel Inbound",
      "position": [-900, -400],
      "webhookId": "sdd-inbound",
      "parameters": { "httpMethod": "POST", "path": "sdd-inbound", "responseMode": "responseNode" },
      "typeVersion": 2
    },
    {
      "type": "n8n-nodes-base.set",
      "name": "Normalize + Inject tenant_id",
      "position": [-680, -400],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "tenant_id", "value": "={{ $json.headers['x-tenant-id'] || 'demo_tenant' }}", "type": "string" },
            { "name": "chat_id", "value": "={{ $json.chat_id || $json.from || 'unknown' }}", "type": "string" },
            { "name": "message_type", "value": "={{ $json.message_type || 'text' }}", "type": "string" },
            { "name": "payload", "value": "={{ $json.payload || $json.body || $json }}", "type": "object" }
          ]
        }
      },
      "typeVersion": 3.4
    },
    {
      "type": "n8n-nodes-base.switch",
      "name": "Router: Message Type",
      "position": [-440, -400],
      "parameters": {
        "rules": {
          "values": [
            { "outputKey": "text", "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.message_type }}", "operator": { "type": "string", "operation": "equals" }, "rightValue": "text" }] } },
            { "outputKey": "audio", "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.message_type }}", "operator": { "type": "string", "operation": "equals" }, "rightValue": "audio" }] } },
            { "outputKey": "location", "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.message_type }}", "operator": { "type": "string", "operation": "equals" }, "rightValue": "location" }] } }
          ]
        },
        "options": { "fallbackOutput": "extra", "renameFallbackOutput": "unsupported" }
      },
      "typeVersion": 3.2
    },
    {
      "type": "n8n-nodes-base.set",
      "name": "Audio/Location Normalizer",
      "position": [-440, -160],
      "parameters": {
        "assignments": {
          "assignments": [
            { "name": "processed_text", "value": "={{ $json.message_type === 'audio' ? '[Audio Transcribed]' : `[Location: ${$json.lat}, ${$json.lng}]` }}", "type": "string" }
          ]
        }
      },
      "typeVersion": 3.4
    },
    {
      "type": "@n8n/n8n-nodes-langchain.agent",
      "name": "AI Agent Core",
      "position": [-160, -400],
      "parameters": {
        "text": "={{ $json.processed_text || $json.payload.text || '' }}",
        "options": {
          "systemMessage": "=# ROL\nEres un asistente SDD-compliant para {{ $json.tenant_id }}.\n# CONSTRAINTS\n- NUNCA ejecutes queries sin tenant_id = '{{ $json.tenant_id }}'\n- Límite de contexto: 40 mensajes\n- Tiempo máximo de respuesta: 30s\n# TOOLS DISPONIBLES\n- qdrant_search: búsqueda vectorial filtrada por tenant\n- db_query: consultas SQL con WHERE tenant_id = ?\n- calendar_tool: reservas con validación de slot\n- http_tool: APIs externas con timeout 30000ms"
        },
        "promptType": "define",
        "hasOutputParser": true
      },
      "typeVersion": 3
    },
    {
      "type": "@n8n/n8n-nodes-langchain.memoryPostgresChat",
      "name": "Memory: Postgres Session",
      "position": [-160, -160],
      "parameters": {
        "sessionKey": "={{ $json.tenant_id }}:{{ $json.chat_id }}",
        "sessionIdType": "customKey",
        "contextWindowLength": 40
      },
      "typeVersion": 1.3
    },
    {
      "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
      "name": "Tool: Qdrant RAG",
      "position": [80, -240],
      "parameters": {
        "mode": "retrieve-as-tool",
        "toolName": "qdrant_search",
        "toolDescription": "Busca documentos en vector DB. FILTRA SIEMPRE por tenant_id en metadata.",
        "qdrantCollection": "={{ $('Config').first().json.qdrant_collection }}",
        "topK": 5
      },
      "typeVersion": 1
    },
    {
      "type": "n8n-nodes-base.mySql",
      "name": "Tool: DB Query",
      "position": [80, 0],
      "parameters": {
        "query": "=SELECT id, data FROM interactions WHERE tenant_id = ? AND chat_id = ? ORDER BY created_at DESC LIMIT 10",
        "operation": "executeQuery"
      },
      "typeVersion": 2.4
    },
    {
      "type": "n8n-nodes-base.httpRequest",
      "name": "Tool: External API",
      "position": [80, 240],
      "parameters": {
        "url": "={{ $('Config').first().json.crm_endpoint }}",
        "method": "POST",
        "timeout": 30000,
        "retryOnFail": true,
        "maxTries": 3,
        "headers": { "tenant-id": "={{ $json.tenant_id }}", "Authorization": "={{ $env.CRM_API_KEY }}" },
        "options": {}
      },
      "typeVersion": 4.2
    },
    {
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "name": "Parser: Structured Output",
      "position": [320, -240],
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"tenant_id\": { \"type\": \"string\" },\n    \"response_text\": { \"type\": \"string\" },\n    \"action\": { \"type\": \"string\", \"enum\": [\"reply\", \"schedule\", \"log\", \"escalate\"] },\n    \"data_payload\": { \"type\": \"object\" }\n  },\n  \"required\": [\"tenant_id\", \"response_text\", \"action\"]\n}"
      },
      "typeVersion": 1.3
    },
    {
      "type": "n8n-nodes-base.code",
      "name": "Audit Log + Validation",
      "position": [560, -240],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nif (!item.tenant_id || item.tenant_id === 'demo_tenant') throw new Error('C4 VIOLATION: tenant_id missing');\nreturn [{ json: { ...item, logged_at: new Date().toISOString(), sha256: 'computed_in_db' } }];"
      },
      "typeVersion": 2
    },
    {
      "type": "n8n-nodes-base.respondToWebhook",
      "name": "Response Node",
      "position": [760, -240],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'ok', tenant_id: $json.tenant_id, reply: $json.response_text }) }}"
      },
      "typeVersion": 1
    }
  ],
  "connections": {
    "Trigger: Multi-Channel Inbound": { "main": [[{ "node": "Normalize + Inject tenant_id", "type": "main", "index": 0 }]] },
    "Normalize + Inject tenant_id": { "main": [[{ "node": "Router: Message Type", "type": "main", "index": 0 }]] },
    "Router: Message Type": { "main": [
      [{ "node": "AI Agent Core", "type": "main", "index": 0 }],
      [{ "node": "Audio/Location Normalizer", "type": "main", "index": 0 }],
      [{ "node": "Audio/Location Normalizer", "type": "main", "index": 0 }]
    ]},
    "Audio/Location Normalizer": { "main": [[{ "node": "AI Agent Core", "type": "main", "index": 0 }]] },
    "AI Agent Core": { "main": [[{ "node": "Parser: Structured Output", "type": "main", "index": 0 }]] },
    "Memory: Postgres Session": { "ai_memory": [[{ "node": "AI Agent Core", "type": "ai_memory", "index": 0 }]] },
    "Tool: Qdrant RAG": { "ai_tool": [[{ "node": "AI Agent Core", "type": "ai_tool", "index": 0 }]] },
    "Tool: DB Query": { "ai_tool": [[{ "node": "AI Agent Core", "type": "ai_tool", "index": 0 }]] },
    "Tool: External API": { "ai_tool": [[{ "node": "AI Agent Core", "type": "ai_tool", "index": 0 }]] },
    "Parser: Structured Output": { "ai_outputParser": [[{ "node": "AI Agent Core", "type": "ai_outputParser", "index": 0 }]] },
    "Parser: Structured Output": { "main": [[{ "node": "Audit Log + Validation", "type": "main", "index": 0 }]] },
    "Audit Log + Validation": { "main": [[{ "node": "Response Node", "type": "main", "index": 0 }]] }
  }
}


