    "constraint_inheritance_logic": {
      "description": "Cómo se heredan y aplican constraints desde norms-matrix.json a artifacts específicos",
      "rules": [
        {
          "rule_id": "CI-001",
          "description": "constraints_mapped en artifact DEBE ser subconjunto de constraints_allowed para su carpeta",
          "validation": "constraints_mapped ⊆ norms-matrix[carpeta].constraints_allowed",
          "failure_action": "blocking_issue: CONSTRAINT_NOT_ALLOWED"
        },
        {
          "rule_id": "CI-002",
          "description": "constraints_mandatory para la carpeta DEBEN estar incluidas en constraints_mapped del artifact",
          "validation": "norms-matrix[carpeta].constraints_mandatory ⊆ constraints_mapped",
          "failure_action": "blocking_issue: MANDATORY_CONSTRAINT_MISSING"
        },
        {
          "rule_id": "CI-003",
          "description": "Constraints vectoriales (V1-V3) SOLO aplican en postgresql-pgvector/",
          "validation": "if carpeta != 'postgresql-pgvector/' then V1,V2,V3 ∉ constraints_mapped",
          "failure_action": "blocking_issue: VECTOR_CONSTRAINT_OUTSIDE_DOMAIN"
        },
        {
          "rule_id": "CI-004",
          "description": "LANGUAGE LOCK: operadores prohibidos no pueden aparecer en contenido del artifact",
          "validation": "scan content for deny_operators from norms-matrix[carpeta]",
          "failure_action": "blocking_issue: LANGUAGE_LOCK_VIOLATION"
        }
      ]
    },

