{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MANTIS AGENTIC - Skill Output Validation Schema",
  "type": "object",
  "required": ["tenant_id", "model_provider", "skill_domain", "constraints_verified", "execution_context", "output_payload", "audit_metadata"],
  "properties": {
    "tenant_id": {"type": "string", "pattern": "^[a-z0-9-]{8,36}$"},
    "model_provider": {"type": "string", "enum": ["openrouter", "qwen", "deepseek", "llama", "gemini", "gpt", "minimax", "mistral-ocr", "voice-agent", "image-gen", "video-gen"]},
    "skill_domain": {"type": "string", "enum": ["INFRASTRUCTURA", "BASE-DE-DATOS-RAG", "COMUNICACION", "SEGURIDAD", "AI", "RESTAURANTES", "ODONTOLOGIA", "HOTELES-POSADAS", "INSTAGRAM-SOCIAL-MEDIA"]},
    "constraints_verified": {"type": "array", "items": {"type": "string", "enum": ["C1","C2","C3","C4","C5","C6"]}, "minItems": 1},
    "execution_context": {
      "type": "object",
      "required": ["timeout_ms", "memory_limit_mb", "tenant_filter"],
      "properties": {
        "timeout_ms": {"type": "integer", "minimum": 1000, "maximum": 300000},
        "memory_limit_mb": {"type": "integer", "minimum": 128, "maximum": 4096},
        "tenant_filter": {"type": "string", "pattern": "^tenant_id\\s*[=:]\\s*['\"]?\\$\\{?tenant_id\\}?"}
      }
    },
    "output_payload": {
      "type": "object",
      "required": ["examples", "validation_rules", "executable_artifacts"],
      "properties": {
        "examples": {"type": "array", "minItems": 5, "items": {"type": "object", "required": ["id", "prompt_template", "c1_c6_compliance", "executable_snippet"]}},
        "executable_artifacts": {"type": "array", "items": {"type": "object", "required": ["filename", "content_type", "content", "sha256"]}}
      }
    },
    "audit_metadata": {
      "type": "object",
      "required": ["generated_at", "validator_version", "output_sha256", "validation_status"],
      "properties": {
        "output_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "validation_status": {"type": "string", "enum": ["passed", "failed", "warnings"]},
        "ci_cd_ready": {"type": "boolean"}
      }
    }
  },
  "additionalProperties": false
}
