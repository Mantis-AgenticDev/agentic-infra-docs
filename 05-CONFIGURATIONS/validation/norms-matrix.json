  "extension_decision_rules": {
    ".md": {
      "description": "Decision rules for Markdown files (documentation/skills)",
      "rules": [
        {
          "condition": "file_path contains 'BASE DE DATOS-RAG' OR 'INFRAESTRUCTURA' OR 'VERTICALES'",
          "actions": [
            "C4 (tenant_id) MANDATORY in all inline code examples",
            "C3 (secrets) applies to any credential placeholder",
            "C5 (examples) requires ≥10 with format ✅/❌/🔧"
          ]
        },
        {
          "condition": "default",
          "actions": [
            "C5 requires ≥5 examples",
            "C4 applies only if file mentions queries or payloads"
          ]
        }
      ]
    },
    ".yaml": {
      "description": "Decision rules for YAML files (Docker, Promptfoo, CI/CD)",
      "rules": [
        "C1/C2: mem_limit, cpus, pids_limit, timeout declared explicitly",
        "C3: ZERO hardcode; use ${VAR:?missing} or env_file references",
        "C4: tenant_id in labels, networks, volumes, environment",
        "C7: healthcheck + restart policy on critical services",
        "C8: logging driver json-file + structured context",
        "Validator: yq eval + docker compose config --quiet (if applicable)"
      ]
    },
    ".tf": {
      "description": "Decision rules for Terraform files",
      "rules": [
        "C1/C2: validation {} blocks for resource ranges",
        "C3: sensitive = true on secret outputs; default = null + TF_VAR_*",
        "C4: tenant_id as required variable with regex validation",
        "C5: checksums in backup/artifact outputs",
        "C6: validation prohibiting localhost in inference endpoints",
        "Validator: terraform fmt -check + terraform validate -no-color -json"
      ]
    },
    ".sh": {
      "description": "Decision rules for Bash scripts",
      "rules": [
        "Frontmatter COMMENTED with # (for bash compatibility)",
        "Shebang #!/bin/bash + set -euo pipefail mandatory",
        "C3: ${VAR:?missing} in all credentials",
        "C4: tenant_id injected in logs, paths, queries",
        "C7: timeout in curl/wget, retry with backoff if applicable",
        "C8: JSON output via heredoc (cat <<EOF | jq .)",
        "Validator: shellcheck + bash -n + audit-secrets.sh"
      ]
    },
    ".json": {
      "description": "Decision rules for JSON files (n8n workflows, schemas)",
      "rules": [
        "Strict syntax: jq empty must pass",
        "C3: No secrets exposed in JSON; use ${ENV_VAR} or references",
        "C4: tenant_id in payloads, filters, node metadata",
        "C5: Schema validation against skill-input-output.schema.json",
        "C7: Error handling nodes, retry, timeout declared",
        "Validator: schema-validator.py + jq empty + audit-secrets"
      ]
    }
  },
  "special_cases": [
    {
      "case": "02-SKILLS/BASE DE DATOS-RAG/*.md with inline SQL",
      "treatment": "C4 (tenant_id) MANDATORY in ALL example queries",
      "justification": "Core of multi-tenant isolation; a single SELECT * without filter breaks architecture",
      "enforcement": "check-rls.sh --strict blocks certification if any query lacks WHERE tenant_id=?"
    },
    {
      "case": "05-CONFIGURATIONS/environment/.env.example",
      "treatment": "C3 applies but accepts placeholders replace_with_... OR ${VAR:?missing}",
      "justification": "Template file, not executable; validator must accept both patterns",
      "enforcement": "audit-secrets.sh --template-mode"
    },
    {
      "case": "07-PROCEDURES/*.md",
      "treatment": "C5 requires only 3 examples (not 5/10)",
      "justification": "Operational checklists, not code; value is in clarity, not technical exhaustiveness",
      "enforcement": "validate-frontmatter.sh --procedure-mode"
    },
    {
      "case": "08-LOGS/*.json",
      "treatment": "C3/C4/C5 mandatory, but C1/C2/C6/C7 not applicable",
      "justification": "Audit outputs, not executable configs; focus is integrity and isolation, not resources",
      "enforcement": "schema-validator.py --audit-mode"
    },
    {
      "case": "Files in 09-TEST-SANDBOX/",
      "treatment": "All norms apply, but max tier is 1 (no merge to prod without explicit promotion)",
      "justification": "Test zone; final certification occurs only after promotion to production folder",
      "enforcement": "orchestrator-engine.sh blocks tier >1 for sandbox paths"
    }
  ],
  "ai_generation_prompt_checklist": {
    "description": "Mandatory checklist to include in ALL AI generation prompts",
    "items": [
      "Before generating, read PROJECT_TREE.md and resolve:",
      "1. Exact canonical path of file to create",
      "2. Extension → apply validation rules by type (see C1-C8 matrix)",
      "3. Function → determine target tier (1/2/3) and required examples (5/10)",
      "4. Dominant constraints → C4 mandatory if path contains 'DB-RAG', 'INFRA', 'VERTICAL'",
      "5. Frontmatter → commented if .sh, pure YAML if .md/.yaml/.tf/.json",
      "6. Zero hardcode → use ${VAR:?missing} or sensitive = true",
      "7. tenant_id → present in queries, labels, logs, payloads if applicable",
      "8. Examples → ≥5 (Tier 1) or ≥10 (Tier 2-3) with format ✅/❌/🔧",
      "9. Validation command → executable and specific to this file type",
      "10. If context missing: '⚠️ BLOCKED: missing [X]. Awaiting context.' and STOP."
    ]
  },
  "orchestrator_integration_notes": {
    "matrix_lookup_strategy": "Use longest prefix match on file_path to find most specific matrix entry",
    "validator_execution": "Only execute validators marked as applicable/mandatory for the resolved profile",
    "tier_calculation": "Calculate achieved tier based on passed checks + examples count + functional requirements",
    "blocking_behavior": "If any mandatory check fails, return exit code 2 immediately without tier calculation",
    "json_output_schema": {
      "file": "string (canonical path)",
      "tier_certified": "integer (1|2|3) or null if blocked",
      "passed_checks": ["C1", "C2", "C3", "C4", "C5", "C6", "C7", "C8"],
      "blocking_issues": [{"constraint": "C4", "message": "tenant_id missing in query line 42"}],
      "warnings": [{"constraint": "C8", "message": "structured logging not detected but recommended"}],
      "next_action": "string ('review_human'|'merge_auto'|'trigger_deploy'|'correct_and_retry')",
      "sha256": "string (for tier 3 artifacts)",
      "timestamp": "ISO8601 string"
    }
  },
  "version_history": [
    {"version": "1.0.0", "date": "2026-04-14", "changes": ["Initial matrix definition", "All canonical locations mapped", "C1-C8 intensity rules defined", "Validator routing logic specified"]}
  ],
