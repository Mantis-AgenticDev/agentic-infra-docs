{
  "title": "Norms Application Matrix by Canonical Location",
  "version": "1.0.0",
  "constraints_mapped": ["C1", "C2", "C3", "C4", "C5", "C6", "C7", "C8"],
  "validation_command": "./05-CONFIGURATIONS/validation/orchestrator-engine.sh --mode headless --file 05-CONFIGURATIONS/validation/norms-matrix.json --json",
  "canonical_path": "05-CONFIGURATIONS/validation/norms-matrix.json",
  "ai_optimized": true,
  "related_files": [
    "[[05-CONFIGURATIONS/validation/orchestrator-engine.sh]]",
    "[[05-CONFIGURATIONS/00-INDEX.md]]",
    "[[PROJECT_TREE.md]]",
    "[[01-RULES/00-INDEX.md]]",
    "[[01-RULES/01-ARCHITECTURE-RULES.md]]",
    "[[01-RULES/02-RESOURCE-GUARDRAILS.md]]",
    "[[01-RULES/03-SECURITY-RULES.md]]",
    "[[01-RULES/04-API-RELIABILITY-RULES.md]]",
    "[[01-RULES/05-CODE-PATTERNS-RULES.md]]",
    "[[01-RULES/06-MULTITENANCY-RULES.md]]",
    "[[01-RULES/07-SCALABILITY-RULES.md]]",
    "[[02-SKILLS/00-INDEX.md]]",
    "[[02-SKILLS/BASE DE DATOS-RAG/00-INDEX.md]]",
    "[[02-SKILLS/INFRAESTRUCTURA/00-INDEX.md]]",
    "[[05-CONFIGURATIONS/validation/audit-secrets.sh]]",
    "[[05-CONFIGURATIONS/validation/check-rls.sh]]",
    "[[05-CONFIGURATIONS/validation/check-wikilinks.sh]]",
    "[[05-CONFIGURATIONS/validation/verify-constraints.sh]]",
    "[[05-CONFIGURATIONS/validation/schema-validator.py]]"
  ],
  "master_precedence_rule": {
    "description": "Rule of precedence for norm application based on canonical location",
    "logic": [
      {
        "condition": "file_path contains '05-CONFIGURATIONS/' OR '04-WORKFLOWS/'",
        "action": "Apply C1-C8 COMPLETE (Tier 2-3 target)"
      },
      {
        "condition": "file_path contains '02-SKILLS/BASE DE DATOS-RAG/' OR '02-SKILLS/INFRAESTRUCTURA/'",
        "action": "C4 MANDATORY + C1-C3/C7 contextual based on function"
      },
      {
        "condition": "file_extension is '.md' AND file_path contains '00-CONTEXT/' OR '01-RULES/' OR '07-PROCEDURES/'",
        "action": "C5/C8 + valid frontmatter (Tier 1 target)"
      },
      {
        "condition": "default fallback",
        "action": "Minimum validation (syntax + wikilinks only)"
      }
    ]
  },
  "intensity_legend": {
    "mandatory": {
      "symbol": "🔴",
      "behavior": "Automatic failure if not met. Blocks tier certification. Exit code 2.",
      "example_validators": ["audit-secrets.sh", "check-rls.sh --strict", "terraform validate"]
    },
    "applicable": {
      "symbol": "🟢",
      "behavior": "Must be present and verifiable. Warning for Tier 2-3 if missing, allows Tier 1 with correction.",
      "example_validators": ["verify-constraints.sh", "validate-frontmatter.sh"]
    },
    "contextual": {
      "symbol": "🟡",
      "behavior": "Applies only if file function requires it. Checked conditionally based on inline content analysis.",
      "example_validators": ["check-rls.sh --inline-sql", "grep -q 'tenant_id'"]
    },
    "not_applicable": {
      "symbol": "⚪",
      "behavior": "Norm irrelevant for this file type. Omitted from validation report entirely.",
      "example_validators": []
    }
  },
  "matrix_by_location": {
    "00-CONTEXT/": {
      "description": "Base documentation, user/project context files",
      "extensions": {
        ".md": {
          "function": "documentation_base",
          "constraints": {
            "C1": {"intensity": "not_applicable", "validator": null},
            "C2": {"intensity": "not_applicable", "validator": null},
            "C3": {"intensity": "not_applicable", "validator": null},
            "C4": {"intensity": "not_applicable", "validator": null},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 5},
            "C6": {"intensity": "not_applicable", "validator": null},
            "C7": {"intensity": "not_applicable", "validator": null},
            "C8": {"intensity": "contextual", "validator": "verify-constraints.sh", "condition": "if file mentions logging/observability"}
          },
          "tier_requirements": {"min": 1, "examples_min": 5, "validation_command_required": false},
          "active_validators": ["check-wikilinks.sh", "validate-frontmatter.sh"]
        }
      }
    },
    "01-RULES/": {
      "description": "Canonical norms, C1-C8 constraint definitions",
      "extensions": {
        ".md": {
          "function": "canonical_rules",
          "constraints": {
            "C1": {"intensity": "not_applicable", "validator": null},
            "C2": {"intensity": "not_applicable", "validator": null},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 5},
            "C6": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C7": {"intensity": "not_applicable", "validator": null},
            "C8": {"intensity": "not_applicable", "validator": null}
          },
          "tier_requirements": {"min": 2, "examples_min": 5, "validation_command_required": true},
          "active_validators": ["verify-constraints.sh", "audit-secrets.sh", "validate-frontmatter.sh"]
        }
      }
    },
    "02-SKILLS/AI/": {
      "description": "AI model integration patterns (OpenRouter, Qwen, etc.)",
      "extensions": {
        ".md": {
          "function": "ai_integration_pattern",
          "constraints": {
            "C1": {"intensity": "not_applicable", "validator": null},
            "C2": {"intensity": "not_applicable", "validator": null},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "not_applicable", "validator": null},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 5},
            "C6": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C7": {"intensity": "not_applicable", "validator": null},
            "C8": {"intensity": "contextual", "validator": "verify-constraints.sh", "condition": "if file mentions structured logging"}
          },
          "tier_requirements": {"min": 1, "max": 2, "examples_min": 5, "validation_command_required": true},
          "active_validators": ["audit-secrets.sh", "verify-constraints.sh", "check-wikilinks.sh"]
        }
      }
    },
    "02-SKILLS/INFRAESTRUCTURA/": {
      "description": "Infrastructure patterns: Docker, SSH, UFW, monitoring",
      "extensions": {
        ".md": {
          "function": "infrastructure_pattern",
          "constraints": {
            "C1": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C2": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 10},
            "C6": {"intensity": "not_applicable", "validator": null},
            "C7": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 2, "examples_min": 10, "validation_command_required": true},
          "active_validators": ["verify-constraints.sh", "check-wikilinks.sh", "audit-secrets.sh"]
        }
      }
    },
    "02-SKILLS/BASE DE DATOS-RAG/": {
      "description": "Database schemas, RAG ingestion, multi-tenant queries",
      "extensions": {
        ".md": {
          "function": "database_schema_with_inline_sql",
          "constraints": {
            "C1": {"intensity": "contextual", "validator": "verify-constraints.sh", "condition": "if file mentions resource limits"},
            "C2": {"intensity": "contextual", "validator": "verify-constraints.sh", "condition": "if file mentions concurrency/timeout"},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "mandatory", "validator": "check-rls.sh --strict", "blocking": true, "checks": ["tenant_id in all WHERE clauses", "tenant_id as second field in tables", "composite indexes start with tenant_id", "FK references tenants table"]},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 10},
            "C6": {"intensity": "not_applicable", "validator": null},
            "C7": {"intensity": "not_applicable", "validator": null},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 2, "examples_min": 10, "validation_command_required": true, "c4_blocking": true},
          "active_validators": ["check-rls.sh", "audit-secrets.sh", "schema-validator.py", "verify-constraints.sh"]
        }
      }
    },
    "02-SKILLS/WHATSAPP-RAG AGENTS/": {
      "description": "WhatsApp agents with RAG + multi-tenant awareness",
      "extensions": {
        ".md": {
          "function": "whatsapp_rag_agent_pattern",
          "constraints": {
            "C1": {"intensity": "contextual", "validator": "verify-constraints.sh"},
            "C2": {"intensity": "contextual", "validator": "verify-constraints.sh"},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "mandatory", "validator": "verify-constraints.sh", "blocking": true},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 10},
            "C6": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C7": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 2, "examples_min": 10, "validation_command_required": true},
          "active_validators": ["audit-secrets.sh", "verify-constraints.sh", "check-wikilinks.sh"]
        }
      }
    },
    "02-SKILLS/VERTICALES/": {
      "description": "Industry-specific skills (restaurant, dental, hotel, etc.)",
      "extensions": {
        ".md": {
          "function": "vertical_skill_pattern",
          "constraints": {
            "C1": {"intensity": "contextual", "validator": "verify-constraints.sh"},
            "C2": {"intensity": "contextual", "validator": "verify-constraints.sh"},
            "C3": {"intensity": "applicable", "validator": "audit-secrets.sh"},
            "C4": {"intensity": "mandatory", "validator": "check-rls.sh --if-db", "blocking": true},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh", "min_examples": 10},
            "C6": {"intensity": "not_applicable", "validator": null},
            "C7": {"intensity": "contextual", "validator": "verify-constraints.sh"},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 1, "max": 2, "examples_min": 10, "validation_command_required": true},
          "active_validators": ["check-rls.sh --if-db", "audit-secrets.sh", "verify-constraints.sh"]
        }
      }
    },
    "03-AGENTS/infrastructure/": {
      "description": "Infrastructure agent definitions (monitoring, backup, alerts)",
      "extensions": {
