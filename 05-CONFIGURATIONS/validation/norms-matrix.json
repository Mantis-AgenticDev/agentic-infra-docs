  "footer_validation": "# 🟢 VALIDATION: ./05-CONFIGURATIONS/validation/orchestrator-engine.sh --mode headless --file 05-CONFIGURATIONS/validation/norms-matrix.json --json && jq '.tier_certified' skill-validation-report.json"
