    "05-CONFIGURATIONS/validation/": {
      "description": "Validation and integrity scripts",
      "extensions": {
        ".sh": {
          "function": "validation_script_executable",
          "constraints": {
            "C1": {"intensity": "not_applicable", "validator": null},
