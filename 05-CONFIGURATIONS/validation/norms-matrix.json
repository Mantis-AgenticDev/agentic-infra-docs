    "04-WORKFLOWS/": {
      "description": "Exported n8n workflows (executable JSON)",
      "extensions": {
        ".json": {
          "function": "n8n_workflow_executable",
          "constraints": {
            "C1": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C2": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C3": {"intensity": "mandatory", "validator": "audit-secrets.sh", "blocking": true},
            "C4": {"intensity": "mandatory", "validator": "schema-validator.py", "blocking": true, "checks": ["tenant_id in node parameters", "tenant_id in filters", "tenant_id in metadata"]},
            "C5": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C6": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C7": {"intensity": "applicable", "validator": "schema-validator.py", "checks": ["error handling nodes", "retry configuration", "timeout settings"]},
            "C8": {"intensity": "applicable", "validator": "schema-validator.py"}
          },
          "tier_requirements": {"min": 3, "examples_min": 10, "validation_command_required": true, "requires_packager": true},
          "active_validators": ["schema-validator.py", "packager-assisted.sh", "audit-secrets.sh", "jq empty"]
        }
      }
    },
    "04-WORKFLOWS/n8n/": {
      "description": "Function-specific n8n workflows",
      "extensions": {
        ".json": {
          "function": "n8n_workflow_functional",
          "constraints": {
            "C1": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C2": {"intensity": "applicable", "validator": "schema-validator.py"},
            "C3": {"intensity": "mandatory", "validator": "audit-secrets.sh", "blocking": true},
