            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 2, "examples_min": 10, "validation_command_required": true},
          "active_validators": ["audit-secrets.sh", "verify-constraints.sh", "check-wikilinks.sh"]
        }
      }
