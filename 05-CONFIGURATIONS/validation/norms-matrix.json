            "C4": {"intensity": "mandatory", "validator": "verify-constraints.sh", "blocking": true},
            "C5": {"intensity": "mandatory", "validator": "promptfoo_dry_run", "checks": ["assertions present", "test cases ≥5 per model"]},
            "C6": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C7": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
