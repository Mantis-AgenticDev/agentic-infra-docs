        }
      }
    },
    "05-CONFIGURATIONS/docker-compose/": {
      "description": "Container configuration for VPS deployment",
      "extensions": {
        ".yml": {
          "function": "docker_compose_config",
          "constraints": {
            "C1": {"intensity": "mandatory", "validator": "docker_compose_check", "blocking": true, "checks": ["mem_limit declared", "memswap_limit equals mem_limit", "no swap usage"]},
            "C2": {"intensity": "mandatory", "validator": "docker_compose_check", "blocking": true, "checks": ["cpus declared", "pids_limit declared", "timeout settings"]},
            "C3": {"intensity": "mandatory", "validator": "audit-secrets.sh", "blocking": true, "checks": ["${VAR:?missing} syntax", "no hardcoded credentials", "sensitive ports on 127.0.0.1"]},
            "C4": {"intensity": "mandatory", "validator": "verify-constraints.sh", "blocking": true, "checks": ["tenant_id in labels", "tenant_id in networks", "tenant_id in volumes", "tenant_id in environment"]},
            "C5": {"intensity": "applicable", "validator": "validate-frontmatter.sh"},
            "C6": {"intensity": "not_applicable", "validator": null},
            "C7": {"intensity": "mandatory", "validator": "docker_compose_check", "blocking": true, "checks": ["healthcheck present", "restart: unless-stopped", "retry/backoff config"]},
            "C8": {"intensity": "mandatory", "validator": "verify-constraints.sh", "checks": ["logging driver json-file", "structured log context", "tenant_id in logs"]}
          },
          "tier_requirements": {"min": 3, "examples_min": 10, "validation_command_required": true, "requires_healthcheck": true, "requires_namespace_isolation": true},
          "active_validators": ["docker compose config --quiet", "audit-secrets.sh", "verify-constraints.sh", "yq eval"]
        }
      }
    },
    "05-CONFIGURATIONS/terraform/modules/": {
      "description": "Reusable IaC modules (vps-base, postgres-rls, etc.)",
      "extensions": {
        ".tf": {
          "function": "terraform_module_reusable",
          "constraints": {
            "C1": {"intensity": "mandatory", "validator": "terraform_validate", "blocking": true, "checks": ["validation {} blocks for resource ranges", "mem_limit/cpus constraints"]},
            "C2": {"intensity": "mandatory", "validator": "terraform_validate", "blocking": true},
            "C3": {"intensity": "mandatory", "validator": "audit-secrets.sh", "blocking": true, "checks": ["sensitive = true on secret outputs", "default = null + TF_VAR_* pattern", "no hardcoded values"]},
            "C4": {"intensity": "mandatory", "validator": "verify-constraints.sh", "blocking": true, "checks": ["tenant_id as required variable", "regex validation on tenant_id format", "tenant_id propagated to outputs"]},
            "C5": {"intensity": "mandatory", "validator": "terraform_validate", "checks": ["checksums in backup outputs", "validation_checklist output"]},
            "C6": {"intensity": "applicable", "validator": "verify-constraints.sh", "checks": ["validation prohibiting localhost in inference endpoints"]},
            "C7": {"intensity": "applicable", "validator": "verify-constraints.sh"},
            "C8": {"intensity": "applicable", "validator": "verify-constraints.sh"}
          },
          "tier_requirements": {"min": 3, "examples_min": 10, "validation_command_required": true, "requires_terraform_fmt": true},
          "active_validators": ["terraform fmt -check", "terraform validate -no-color -json", "audit-secrets.sh", "verify-constraints.sh"]
        }
      }
    },
