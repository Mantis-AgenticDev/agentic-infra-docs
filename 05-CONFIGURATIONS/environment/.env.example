# MANTIS ENVIRONMENT TEMPLATE (v2.0.0)
# Propósito: Fuente única de verdad para variables. Copiar a .env.<entorno> y completar valores.
# Regla C3: NUNCA commitear .env.prod/.env.staging con secretos reales. Usar secret manager o git-crypt.

# --- IDENTIFICACIÓN & CLOUD (C4) ---
PROJECT_NAME="mantis" # [type:string] [valid:^[a-z][a-z0-9-]{2,62}$] [constraint:C4]
ENVIRONMENT_TAG="dev" # [type:string] [valid:^(dev|staging|prod)$] [constraint:C4,C6]
AWS_REGION="sa-east-1" # [type:string] [valid:^[a-z]{2}-[a-z]+-[0-9]+$] [constraint:C4]

# --- BASE DE DATOS & PGVECTOR (C3,V1,V2) ---
DATABASE_URL="postgres://localhost:5432/mantis_dev" # [type:connection_string] [valid:^postgres://.*] [constraint:C3,V1]
DB_PASSWORD="" # [type:secret] [injection:docker_secret|vault] [constraint:C3] ⚠️ NO COMPLETAR AQUÍ
PGVECTOR_ENABLED="true" # [type:boolean] [valid:^(true|false)$] [constraint:V1]
PGVECTOR_DIMENSION="1536" # [type:integer] [valid:^[0-9]+$] [constraint:V1]
PGVECTOR_INDEX_TYPE="hnsw" # [type:string] [valid:^(hnsw|ivfflat)$] [constraint:V3]

# --- QDRANT VECTOR SEARCH (C3,V3) ---
QDRANT_ENDPOINT="http://localhost:6333" # [type:url] [valid:^https?://.*] [constraint:V3]
QDRANT_API_KEY="" # [type:secret] [injection:docker_secret] [constraint:C3,V3] ⚠️ NO COMPLETAR AQUÍ

# --- APLICACIÓN & OBSERVABILIDAD (C8) ---
API_PORT="4000" # [type:port] [valid:^([1-9][0-9]{0,4})$] [constraint:C8]
LOG_LEVEL="info" # [type:string] [valid:^(debug|info|warn|error|fatal)$] [constraint:C8]
PROMETHEUS_HOST="http://localhost:9090" # [type:url] [valid:^https?://.*] [constraint:C8]
SLACK_WEBHOOK="" # [type:url/secret] [valid:^https://hooks\.slack\.com/.*] [constraint:C3,C6] ⚠️ NO COMPLETAR AQUÍ

# --- INFRA & SECURITY OVERRIDES ---
SSH_ADMIN_CIDR="10.0.0.0/8" # [type:cidr] [valid:^[0-9]{1,3}(?:\.[0-9]{1,3}){3}/[0-9]{1,2}$]
TF_BACKEND_BUCKET="mantis-state" # [type:string] [valid:^[a-z0-9][a-z0-9-]{2,62}$]
TF_KMS_KEY_ARN="" # [type:arn] Dejar vacío (AWS-managed). Prod requiere ARN customer-managed.

# --- VALIDATION & USAGE COMMANDS ---
# validate_vars: yq eval '.variables | keys' mapping.yaml | sort | diff - <(grep -oP '^[A-Z_]+(?==)' .env.example | sort)
# check_secrets: grep -nE '(DB_PASSWORD|QDRANT_API_KEY|SLACK_WEBHOOK|DB_PASSWORD)=' .env.* | grep -v '""' && exit 1 || exit 0
# align_interface: diff <(yq eval '.variables | keys' mapping.yaml) <(yq eval '.docker_compose_inputs | keys' interface-spec.yaml)
# update_checksum: sha256sum .env.example | awk '{print $1}'
