# ---
# title: "Environment Variables Example - Mantis Agentic Infrastructure"
# version: "1.0.0"
# constraints_mapped: ["C3", "C4", "C6", "C8"]
# validation_command: "./05-CONFIGURATIONS/validation/audit-secrets.sh --check-env 05-CONFIGURATIONS/environment/.env.example"
# ---

# =============================================================================
# ENVIRONMENT VARIABLES EXAMPLE FILE
# =============================================================================
# This file defines all required environment variables for the Mantis Agentic
# infrastructure. Copy to .env and fill with actual secure values.
# NEVER commit .env with real secrets! (C3: zero hardcoding)

# -----------------------------------------------------------------------------
# PROVIDER CREDENTIALS (C3: use env vars, no hardcoded values)
# -----------------------------------------------------------------------------
# VPS Provider (Hetzner/DigitalOcean)
TF_VAR_provider_token=replace_with_actual_token
# PostgreSQL admin password
TF_VAR_admin_password=replace_with_secure_password_min_32_chars
# PostgreSQL application user password
TF_VAR_app_password=replace_with_secure_password_min_32_chars
# Backup encryption key (at least 32 chars)
TF_VAR_encryption_key=replace_with_strong_encryption_key_min_32_chars

# -----------------------------------------------------------------------------
# CLOUDFLARE (DNS & SSL)
# -----------------------------------------------------------------------------
CLOUDFLARE_EMAIL=admin@example.com
CLOUDFLARE_API_TOKEN=replace_with_cloudflare_api_token
LETSENCRYPT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# OPENROUTER API (C6: cloud endpoint only)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-replace_with_actual_key
SERVICE_DOMAIN=https://your-service-domain.com

# -----------------------------------------------------------------------------
# POSTGRESQL DATABASE (Shared across VPS)
# -----------------------------------------------------------------------------
POSTGRES_HOST=your-postgres-host.example.com
POSTGRES_PORT=5432
POSTGRES_DB=mantis_agentic
POSTGRES_USER=mantis_app
POSTGRES_PASSWORD=replace_with_secure_app_password

# -----------------------------------------------------------------------------
# MYSQL (VPS2 - EspoCRM)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=replace_with_secure_root_password
MYSQL_DATABASE=espocrm
MYSQL_USER=espocrm_user
MYSQL_PASSWORD=replace_with_secure_user_password

# -----------------------------------------------------------------------------
# ESPOCRM ADMIN (VPS2)
# -----------------------------------------------------------------------------
ESPOCRM_ADMIN_USER=admin
ESPOCRM_ADMIN_PASSWORD=replace_with_secure_admin_password

# -----------------------------------------------------------------------------
# QDRANT VECTOR DB (VPS2)
# -----------------------------------------------------------------------------
QDRANT_API_KEY=replace_with_secure_qdrant_api_key

# -----------------------------------------------------------------------------
# N8N WORKFLOW AUTOMATION (VPS1 & VPS3)
# -----------------------------------------------------------------------------
# Primary VPS1
N8N_ENCRYPTION_KEY=replace_with_32_char_hex_key
N8N_JWT_SECRET=replace_with_secure_jwt_secret
PUBLIC_DOMAIN=n8n-primary.yourdomain.com

# Secondary VPS3
N8N_ENCRYPTION_KEY_SECONDARY=replace_with_different_32_char_hex_key
N8N_JWT_SECRET_SECONDARY=replace_with_secure_jwt_secret_secondary
PUBLIC_DOMAIN_SECONDARY=n8n-secondary.yourdomain.com

N8N_CONCURRENCY_LIMIT=5

# -----------------------------------------------------------------------------
# UAZAPI WHATSAPP GATEWAY (VPS1 & VPS3)
# -----------------------------------------------------------------------------
# Primary VPS1
UAZAPI_SESSION_SECRET=replace_with_secure_session_secret
UAZAPI_ADMIN_PASSWORD=replace_with_secure_admin_password
UAZAPI_JWT_SECRET=replace_with_secure_jwt_secret

# Secondary VPS3
UAZAPI_SESSION_SECRET_SECONDARY=replace_with_different_session_secret
UAZAPI_ADMIN_PASSWORD_SECONDARY=replace_with_secure_admin_password_secondary
UAZAPI_JWT_SECRET_SECONDARY=replace_with_secure_jwt_secret_secondary

# -----------------------------------------------------------------------------
# MULTI-TENANCY (C4)
# -----------------------------------------------------------------------------
TENANT_ID=tenant-00000000-0000-0000-0000-000000000001
TENANT_ID_ALPHA=tenant-aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
TENANT_ID_BETA=tenant-bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb

# -----------------------------------------------------------------------------
# LOGGING & OBSERVABILITY (C8)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com:4317

# -----------------------------------------------------------------------------
# OPTIONAL: NOTIFICATION WEBHOOKS (Telegram, etc.)
# -----------------------------------------------------------------------------
NOTIFICATION_WEBHOOK_URL=https://api.telegram.org/bot...

# -----------------------------------------------------------------------------
# VALIDATION CHECKLIST (C5)
# -----------------------------------------------------------------------------
# 1. All values marked "replace_with_..." must be changed.
# 2. Ensure no quotes around values unless the value contains spaces.
# 3. Run audit-secrets.sh to verify no hardcoded tokens remain.
# 4. Set restrictive file permissions: chmod 600 .env

# 🟢 VALIDATION: ./05-CONFIGURATIONS/validation/audit-secrets.sh --check-env 05-CONFIGURATIONS/environment/.env.example && echo "✅ .env.example passed secret audit"
